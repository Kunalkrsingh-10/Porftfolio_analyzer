# ============================================================
# Kalpi AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in every value marked
# CHANGE_ME before running docker compose up --build.
# NEVER commit .env to version control.
# ============================================================

# ── App ──────────────────────────────────────────────────────
ENV_MODE=production

# ── Next.js Frontend ────────────────────────────────────────
# URL the browser uses to reach the FastAPI backend.
# Default: http://localhost:8000 (api-service runs on port 8000)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── CORS ────────────────────────────────────────────────────
# Comma-separated. Add your production domain here when deploying.
CORS_ORIGINS=http://localhost:3000

# ── AI / LLM Keys ───────────────────────────────────────────
# Groq is the default LLM provider.
# Get a free key at: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=CHANGE_ME_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (optional — only needed if LLM_PROVIDER=gemini)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=CHANGE_ME_your_gemini_api_key

# ── Databases ────────────────────────────────────────────────
# Pre-configured in docker-compose.yml (MongoDB Atlas + Railway PostgreSQL).
# Override here only if you want to use your own database instances.
# MONGO_URL=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/
# DB_NAME=kalpi_ai_api_db
# DATABASE_URL=postgresql://<user>:<pass>@<host>:<port>/<dbname>

# ── Storage ─────────────────────────────────────────────────
STORAGE_TYPE=local
