# ============================================================
# Kalpi AI — Central Environment Configuration
# ============================================================
# Copy this file to .env and fill in every value marked
# CHANGE_ME before running docker compose up --build.
# NEVER commit .env to version control.
# ============================================================

# ── Deployment ──────────────────────────────────────────────
ENV_MODE=production
# Host port that nginx listens on. Change to e.g. 8080 if 80 is taken.
NGINX_PORT=80

# ── Next.js Frontend ────────────────────────────────────────
# This value is baked into the browser JS bundle at build time.
# It must be the URL your *browser* (not the Docker container) uses to
# reach nginx. If NGINX_PORT=80, this is http://localhost.
# If NGINX_PORT=8080, set this to http://localhost:8080.
NEXT_PUBLIC_API_BASE_URL=http://localhost

# ── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_min_32_random_chars
JWT_SECRET=CHANGE_ME_min_32_random_chars
JWT_ALGORITHM=HS256

# ── CORS ────────────────────────────────────────────────────
# Comma-separated. Add your production domain here when deploying.
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── PostgreSQL (local Docker container) ─────────────────────
# These values are also used by the postgres service to create the database.
POSTGRES_USER=kalpi_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=kalpi_auth_db
# "postgres" is the Docker service name — resolvable inside kalpi-net.
DATABASE_URL=postgresql://kalpi_user:CHANGE_ME_strong_db_password@postgres:5432/kalpi_auth_db
# To use a remote database (Railway, Supabase, etc.) instead, replace the line
# above with your full connection string and comment out POSTGRES_* vars.

# ── MongoDB (local Docker container) ────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
# "mongo" is the Docker service name.
MONGO_URL=mongodb://mongo:27017
DB_NAME=kalpi_ai_api_db
# To use MongoDB Atlas instead:
# MONGO_URL=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/

# ── Storage ─────────────────────────────────────────────────
STORAGE_TYPE=local

# ── AI / LLM Keys ───────────────────────────────────────────
GEMINI_API_KEY=CHANGE_ME_your_gemini_api_key
LLM_PROVIDER=groq
GROQ_API_KEY=CHANGE_ME_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# Uncomment to use Anthropic instead of Groq:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=CHANGE_ME_your_anthropic_key
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
